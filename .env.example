# K-AGIT environment variables — TEMPLATE ONLY
# Copy this file to .env and fill in the values. NEVER commit a real .env.
# Generate any random secret with: openssl rand -base64 32

# --- Flask ---
FLASK_ENV=development
SESSION_SECRET=
PORT=5000

# --- Database (Supabase pooler, transaction mode, port 6543) ---
# Get from Supabase: Project Settings -> Database -> Connection pooling
# Use the kagit_app role, NOT postgres.
DATABASE_URL=postgresql+psycopg://kagit_app:PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres
DB_SCHEMA=kagit

# --- Gemini (chat / TTS / STT / translate / grammar) ---
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Google OAuth ---
# Authorized redirect URI: https://k-agit.com/login/google/authorized
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Allow http for local dev only. Remove in production.
OAUTHLIB_INSECURE_TRANSPORT=1

# --- Admin ---
ADMIN_EMAILS=kevin@synthya.ai

# --- Static asset hosting (Cloudflare R2, Phase 2) ---
# Leave empty in dev to serve from Flask /static. In prod: https://assets.k-agit.com
ASSETS_BASE_URL=
ASSET_VERSION=dev
